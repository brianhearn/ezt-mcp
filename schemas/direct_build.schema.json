{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.easyterritory.com/ezt-mcp/direct_build.schema.json",
  "title": "EZT MCP direct_build Tool Contract",
  "type": "object",
  "$defs": {
    "assignmentRow": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "part_id",
        "territory_path"
      ],
      "properties": {
        "row_id": {
          "type": ["string", "integer"]
        },
        "part_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "territory_path": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "description": "Ordered path of territory labels from root to leaf, e.g. [\"Eastern US\", \"Southeast Region\", \"Florida\"]. Single-element path is equivalent to a flat territory label."
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "request": {
      "allOf": [
        {
          "$ref": "ts-reference.schema.json#/$defs/tsInputRef"
        },
        {
          "type": "object",
          "required": [
            "part_layer",
            "tal_label",
            "assignments"
          ],
          "properties": {
            "part_layer": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "tal_label": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "tal_id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9_-]+$",
              "description": "Optional caller-supplied TAL identifier. When omitted, the server derives a stable ID from tal_label. Supplied IDs must not collide with an existing TAL in the input TS."
            },
            "requested_tal_id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9_-]+$",
              "description": "Compatibility alias for tal_id used by create_territory_from_parts internals."
            },
            "assignments": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/assignmentRow"
              }
            },
            "repair_policy": {
              "type": "string",
              "enum": [
                "default",
                "strict",
                "report_only"
              ],
              "default": "default"
            }
          }
        }
      ]
    },
    "repairSummary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "holes_filled": {
          "type": "integer",
          "minimum": 0
        },
        "contiguity_repairs": {
          "type": "integer",
          "minimum": 0
        },
        "changed_part_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "hierarchySummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4,
          "description": "Deepest level present in the built TAL. 0 = flat (no hierarchy)."
        },
        "leaf_territory_count": {
          "type": "integer",
          "minimum": 0
        },
        "rollup_territory_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "result": {
      "allOf": [
        {
          "$ref": "ts-reference.schema.json#/$defs/tsOutputRef"
        },
        {
          "type": "object",
          "required": [
            "tal_id",
            "territory_count",
            "assignment_summary",
            "hierarchy_summary",
            "repair_summary"
          ],
          "properties": {
            "tal_id": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "territory_count": {
              "type": "integer",
              "minimum": 0,
              "description": "Total territory count including both leaf and rollup nodes."
            },
            "assignment_summary": {
              "type": "object",
              "additionalProperties": true
            },
            "hierarchy_summary": {
              "$ref": "#/$defs/hierarchySummary"
            },
            "repair_summary": {
              "$ref": "#/$defs/repairSummary"
            },
            "invalid_parts": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "submissionResponse": {
      "$ref": "job.schema.json#/$defs/submissionResponse"
    },
    "response": {
      "description": "Completed job result payload returned from the job result path, not from the initial tool submission.",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "ok",
            "result"
          ],
          "properties": {
            "ok": {
              "const": true
            },
            "result": {
              "$ref": "#/$defs/result"
            },
            "warnings": {
              "type": "array",
              "items": {
                "$ref": "common.schema.json#/$defs/warning"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "$ref": "common.schema.json#/$defs/errorEnvelope"
        }
      ]
    }
  }
}
