{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.easyterritory.com/ezt-mcp/realign.schema.json",
  "title": "EZT MCP realign Tool Contract",
  "type": "object",
  "$defs": {
    "partMoveOperation": {
      "title": "Directed Part-Move Operation",
      "type": "object",
      "additionalProperties": false,
      "required": ["part_id", "to_territory_id"],
      "properties": {
        "part_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "from_territory_id": {
          "type": "string",
          "description": "Optional — provided for optimistic validation. If supplied and the part is not currently in this territory, the operation fails with UNKNOWN_SOURCE_TERRITORY."
        },
        "to_territory_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString",
          "description": "Target territory ID within the specified tal_id."
        }
      }
    },
    "request": {
      "allOf": [
        {
          "$ref": "ts-reference.schema.json#/$defs/tsInputRef"
        },
        {
          "type": "object",
          "required": ["tal_id", "moves"],
          "properties": {
            "tal_id": {
              "$ref": "common.schema.json#/$defs/nonEmptyString",
              "description": "Target TAL to realign. Required — ambiguous TAL is an error."
            },
            "part_layer": {
              "type": "string",
              "description": "Part layer name, e.g. us_zips, us_counties. Required when not inferable from the TAL."
            },
            "moves": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/partMoveOperation"
              }
            },
            "repair_policy": {
              "type": "string",
              "enum": ["default", "strict", "report_only"],
              "default": "default"
            },
            "map_session_id": {
              "type": "string",
              "description": "Optional. When supplied and valid, the server notifies this MC session to refresh after a successful realign."
            }
          }
        }
      ]
    },
    "changedTerritory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["territory_id"],
      "properties": {
        "territory_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "territory_label": {
          "type": "string"
        },
        "parts_added": {
          "type": "array",
          "items": { "type": "string" }
        },
        "parts_removed": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "repairSummary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "holes_filled": {
          "type": "integer",
          "minimum": 0
        },
        "contiguity_repairs": {
          "type": "integer",
          "minimum": 0
        },
        "changed_part_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "mapRefreshStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notified"],
      "properties": {
        "notified": {
          "type": "boolean",
          "description": "True if map_session_id was supplied and the refresh notification was sent."
        },
        "map_session_id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["sent", "session_not_found", "session_expired", "skipped"],
          "description": "Granular notification outcome."
        }
      }
    },
    "result": {
      "allOf": [
        {
          "$ref": "ts-reference.schema.json#/$defs/tsOutputRef"
        },
        {
          "type": "object",
          "required": ["tal_id", "moved_part_ids", "changed_territories", "repair_summary"],
          "properties": {
            "tal_id": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "moved_part_ids": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Part IDs that were actually moved (may differ from requested if repair added extra)."
            },
            "changed_territories": {
              "type": "array",
              "items": { "$ref": "#/$defs/changedTerritory" }
            },
            "repair_summary": {
              "$ref": "#/$defs/repairSummary"
            },
            "map_refresh": {
              "$ref": "#/$defs/mapRefreshStatus"
            }
          }
        }
      ]
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "result"],
          "properties": {
            "ok": { "const": true },
            "result": { "$ref": "#/$defs/result" },
            "warnings": {
              "type": "array",
              "items": { "$ref": "common.schema.json#/$defs/warning" }
            }
          }
        },
        {
          "$ref": "common.schema.json#/$defs/errorEnvelope"
        }
      ]
    }
  }
}
