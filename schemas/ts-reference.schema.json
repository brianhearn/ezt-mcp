{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.easyterritory.com/ezt-mcp/ts-reference.schema.json",
  "title": "EZT MCP Territory Solution References",
  "type": "object",
  "$defs": {
    "territorySolution": {
      "title": "Territory Solution GeoJSON FeatureCollection",
      "type": "object",
      "required": [
        "type",
        "features"
      ],
      "properties": {
        "type": {
          "const": "FeatureCollection"
        },
        "features": {
          "type": "array"
        },
        "properties": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "tsIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ts_id",
        "revision",
        "content_hash",
        "updated_at"
      ],
      "properties": {
        "ts_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "revision": {
          "type": "integer",
          "minimum": 0
        },
        "content_hash": {
          "$ref": "common.schema.json#/$defs/sha256Hash"
        },
        "updated_at": {
          "$ref": "common.schema.json#/$defs/isoDateTime"
        }
      }
    },
    "tsHandle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ts_handle",
        "expires_at"
      ],
      "properties": {
        "ts_handle": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "expires_at": {
          "$ref": "common.schema.json#/$defs/isoDateTime"
        },
        "ts_identity": {
          "$ref": "#/$defs/tsIdentity"
        }
      }
    },
    "tsInputRef": {
      "oneOf": [
        {
          "required": [
            "ts"
          ]
        },
        {
          "required": [
            "ts_handle"
          ]
        }
      ],
      "type": "object",
      "properties": {
        "ts": {
          "$ref": "#/$defs/territorySolution"
        },
        "ts_handle": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "expected_revision": {
          "type": "integer",
          "minimum": 0
        },
        "expected_content_hash": {
          "$ref": "common.schema.json#/$defs/sha256Hash"
        }
      },
      "additionalProperties": true
    },
    "tsOutputRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ts_identity"
      ],
      "properties": {
        "ts": {
          "$ref": "#/$defs/territorySolution"
        },
        "ts_handle": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "ts_identity": {
          "$ref": "#/$defs/tsIdentity"
        },
        "expires_at": {
          "$ref": "common.schema.json#/$defs/isoDateTime"
        }
      },
      "anyOf": [
        {
          "required": [
            "ts"
          ]
        },
        {
          "required": [
            "ts_handle"
          ]
        }
      ]
    }
  }
}
