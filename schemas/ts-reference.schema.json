{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.easyterritory.com/ezt-mcp/ts-reference.schema.json",
  "title": "EZT MCP Territory Solution References",
  "type": "object",
  "$defs": {
    "talMetadata": {
      "title": "Territory Alignment Layer Metadata",
      "type": "object",
      "additionalProperties": true,
      "required": ["tal_id", "label", "part_layer"],
      "properties": {
        "tal_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "part_layer": {
          "type": "string",
          "minLength": 1,
          "description": "Single part layer shared by all leaf territories in this TAL, e.g. us_zips, us_counties."
        },
        "max_depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4,
          "description": "Maximum depth of the territory hierarchy within this TAL. 0 means flat (no hierarchy)."
        }
      }
    },
    "territoryFeatureProperties": {
      "title": "Territory Feature Properties",
      "type": "object",
      "additionalProperties": true,
      "required": ["territory_id", "label", "tal_id", "depth", "is_leaf", "part_ids"],
      "properties": {
        "territory_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "tal_id": { "type": "string", "minLength": 1 },
        "depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4,
          "description": "Depth of this territory in the TAL hierarchy. 0 = root. Max 4 (5 levels total)."
        },
        "parent_territory_id": {
          "type": ["string", "null"],
          "description": "territory_id of the parent, or null for root-level territories."
        },
        "is_leaf": {
          "type": "boolean",
          "description": "True if this territory holds part_ids directly. False if it is a rollup/grouping node."
        },
        "part_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Part IDs assigned to this territory. Empty array for rollup territories."
        }
      }
    },
    "territorySolution": {
      "title": "Territory Solution GeoJSON FeatureCollection",
      "type": "object",
      "required": [
        "type",
        "features"
      ],
      "properties": {
        "type": {
          "const": "FeatureCollection"
        },
        "features": {
          "type": "array"
        },
        "properties": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "tsIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ts_id",
        "revision",
        "content_hash",
        "updated_at"
      ],
      "properties": {
        "ts_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "revision": {
          "type": "integer",
          "minimum": 0
        },
        "content_hash": {
          "$ref": "common.schema.json#/$defs/sha256Hash"
        },
        "updated_at": {
          "$ref": "common.schema.json#/$defs/isoDateTime"
        }
      }
    },
    "tsHandle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ts_handle",
        "expires_at"
      ],
      "properties": {
        "ts_handle": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "expires_at": {
          "$ref": "common.schema.json#/$defs/isoDateTime"
        },
        "ts_identity": {
          "$ref": "#/$defs/tsIdentity"
        }
      }
    },
    "tsInputRef": {
      "oneOf": [
        {
          "required": [
            "ts"
          ]
        },
        {
          "required": [
            "ts_handle"
          ]
        }
      ],
      "type": "object",
      "properties": {
        "ts": {
          "$ref": "#/$defs/territorySolution"
        },
        "ts_handle": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "expected_revision": {
          "type": "integer",
          "minimum": 0
        },
        "expected_content_hash": {
          "$ref": "common.schema.json#/$defs/sha256Hash"
        }
      },
      "additionalProperties": true
    },
    "tsOutputRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ts_identity"
      ],
      "properties": {
        "ts": {
          "$ref": "#/$defs/territorySolution"
        },
        "ts_handle": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "ts_identity": {
          "$ref": "#/$defs/tsIdentity"
        },
        "expires_at": {
          "$ref": "common.schema.json#/$defs/isoDateTime"
        }
      },
      "anyOf": [
        {
          "required": [
            "ts"
          ]
        },
        {
          "required": [
            "ts_handle"
          ]
        }
      ]
    }
  }
}
